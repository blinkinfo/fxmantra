# fxmantra - Environment Variables

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# App Wallet (receives deposits, sends withdrawals)
APP_WALLET_PRIVATE_KEY=""
NEXT_PUBLIC_APP_WALLET_ADDRESS=""

# Chain RPC (Base mainnet)
RPC_URL="https://mainnet.base.org"

# Cron secret (protects /api/cron/accrue)
CRON_SECRET=""

# Vercel (auto-set)
# VERCEL_URL
